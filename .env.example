# Docker Registry Configuration
DOCKER_REGISTRY=registry.digitalocean.com
DOCKER_USERNAME=philmander
IMAGE_TAG=latest

# DigitalOcean API Token (for automated push)
# Get from: https://cloud.digitalocean.com/account/api/tokens
# DO_API_TOKEN=your_digitalocean_api_token_here

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info

# Postgres (DO managed database) — used by the deck feedback form.
# In App Platform, bind this to ${db.DATABASE_URL} instead of pasting credentials.
DATABASE_URL=postgresql://user:password@host:25060/db?sslmode=require

# Basic Auth password for safestudios.nl/admin/feedback (any username).
# Generate with: openssl rand -base64 24
ADMIN_PASSWORD=change-me
